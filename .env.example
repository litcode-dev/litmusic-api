# Application
APP_ENV=development
# Generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_THIS_WITH_64_RANDOM_HEX_CHARS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://litmusic:litmusic@db:5432/litmusic

# Redis
REDIS_URL=redis://redis:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-north-1
S3_BUCKET_NAME=litmusic-
S3_ENDPOINT_URL=
S3_CLOUDFRONT_URL=
# Flutterwave
FLW_SECRET_KEY=FLWSECK_TEST-xxxx
FLW_HASH=your-flutterwave-webhook-hash
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxx
FLUTTERWAVE_SECRET_HASH=your-flutterwave-secret-hash
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxx

# Frontend
FRONTEND_URL=https://litmusic.app

# Email (SMTP)
# For Gmail: enable 2FA and create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@litmusic.app

# OneSignal
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_DAYS=30

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
